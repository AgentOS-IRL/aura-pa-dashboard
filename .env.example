# Local environment overrides for the backend health/audio service.
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
PORT=4000
DEEPGRAM_API_KEY=dg-your-key

# Optional Langfuse tracing (set these to enable instrumentation)
LANGFUSE_SECRET_KEY=sk-lf-your-secret
LANGFUSE_PUBLIC_KEY=pk-lf-your-public
LANGFUSE_BASE_URL=https://cloud.langfuse.com  # default; swap if you use a different region or self-host
