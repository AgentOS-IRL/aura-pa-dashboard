{
  "name": "aura-pa-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config ./node_modules/next/dist/bin/next dev --webpack",
    "build": "node ./node_modules/next/dist/bin/next build --webpack",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/lib/cli.js .",
    "test:unit": "vitest run",
    "test": "npm run lint && npm run test:unit"
  },
  "dependencies": {
    "@ricky0123/vad-react": "^0.0.36",
    "copy-webpack-plugin": "^14.0.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "onnxruntime-web": "^1.24.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^22.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.5.0"
  }
}
